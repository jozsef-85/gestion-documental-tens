DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=gestion_documental
DJANGO_DB_USER=gestdoc_user
DJANGO_DB_PASSWORD=gestdoc_password
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

DJANGO_STATIC_ROOT=/opt/gestion_documental/static
DJANGO_MEDIA_ROOT=/opt/gestion_documental/media

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True
DJANGO_SECURE_REFERRER_POLICY=same-origin

DJANGO_LOG_TO_FILE=True
DJANGO_LOG_TO_CONSOLE=False
DJANGO_LOG_DIR=/opt/gestion_documental/logs
DJANGO_APP_LOG_FILE=app.log
DJANGO_SECURITY_LOG_FILE=security.log
DJANGO_LOG_MAX_BYTES=10485760
DJANGO_LOG_BACKUP_COUNT=5
